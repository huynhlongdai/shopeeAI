{
  "manifest_version": 3,
  "name": "shopeeAI",
  "version": "0.5.4",
  "description": "Collects Shopee product data, media, affiliate links, and publishes Facebook wrap jobs from one Chrome extension.",
  "permissions": ["alarms", "clipboardWrite", "downloads", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://shopee.vn/*",
    "https://affiliate.shopee.vn/*",
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://shopee.vn/*", "https://affiliate.shopee.vn/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["facebook-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "shopeeAI"
  },
  "options_page": "manager.html"
}
