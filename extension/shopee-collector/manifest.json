{
  "manifest_version": 3,
  "name": "shopeeAI",
  "version": "0.3.2",
  "description": "Collects Shopee product data, media, and affiliate links from your real Chrome session.",
  "permissions": ["alarms", "clipboardWrite", "downloads", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://shopee.vn/*",
    "https://affiliate.shopee.vn/*",
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://shopee.vn/*", "https://affiliate.shopee.vn/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "shopeeAI"
  },
  "options_page": "manager.html"
}
